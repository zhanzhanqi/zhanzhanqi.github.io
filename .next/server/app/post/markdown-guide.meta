{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/post/layout,_N_T_/post/[id]/layout,_N_T_/post/[id]/page,_N_T_/post/markdown-guide"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/post/$d$id/__PAGE__",
    "/post/$d$id",
    "/post",
    "/_index",
    "/_head"
  ]
}